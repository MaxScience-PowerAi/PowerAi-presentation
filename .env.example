# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL where this app is hosted.
APP_URL="MY_APP_URL"

# Comma-separated list of allowed browser origins for CORS.
# Example: "https://power-ai-presentations.vercel.app,http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# Comma-separated founder passwords (server-side only).
# IMPORTANT: set strong secrets in production; do not commit real values.
FOUNDER_PASSWORDS="change_me_strong_password"
